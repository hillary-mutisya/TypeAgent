{
  "extends": "../../../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "..",
    "lib": ["DOM", "ES2020", "DOM.Iterable"],
    "module": "ESNext",
    "target": "ES2020",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["./client/**/*.ts", "../shared/**/*.ts"],
  "exclude": ["./dist/**/*", "../../../../dist/**/*"],
  "references": [{ "path": "../shared" }]
}
